class Solution {
    public int maxProfit(int[] prices) {
        int p=0;
        int buy =prices[0];
        for(int i=0;i<prices.length;i++)
        {
            int sell=prices[i]-buy;
            p=Math.max(p,sell);
            buy =Math.min(buy,prices[i]);
        }
        return p;
        
    }
}
